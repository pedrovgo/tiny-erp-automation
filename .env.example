# Token da API v2 do Tiny ERP (gerado em: Tiny ERP > Configurações > API)
TINY_API_TOKEN=seu_token_aqui

# URL base da API v2 do Tiny (normalmente não muda)
TINY_API_BASE_URL=https://api.tiny.com.br/api2

# Nível de log: error | warn | info | debug
LOG_LEVEL=info

# Ambiente: development | production
NODE_ENV=development

# Liga/desliga jobs individualmente. Variável: JOB_<NOME_DO_JOB_EM_MAIUSCULO>_ENABLED
# Se a variável não existir, o job fica habilitado por padrão.
JOB_EXEMPLO_PING_TINY_ENABLED=true
JOB_ALTERAR_SITUACAO_PEDIDOS_MERCADO_LIVRE_EM_ABERTO_PARA_NAO_ENTREGUE_ENABLED=true
